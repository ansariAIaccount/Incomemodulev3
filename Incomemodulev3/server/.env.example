# ──────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your Investran credentials.
# .env is gitignored — never commit real secrets.
# ──────────────────────────────────────────────────────────────────

# Proxy listen port (V3 will call http://localhost:<this>/api/diu/...)
PROXY_PORT=4318

# Investran environment base URL (sandbox / UAT / prod)
# Example: https://accounting.investran.fis.com/api/v3
INVESTRAN_BASE_URL=

# OAuth2 client-credentials grant — request from your Investran admin
INVESTRAN_CLIENT_ID=
INVESTRAN_CLIENT_SECRET=

# OAuth scope(s) — comma-separated if multiple
INVESTRAN_OAUTH_SCOPE=dataimport.write

# Optional override of the OAuth token endpoint (defaults to <base>/oauth/token)
INVESTRAN_TOKEN_URL=

# Comma-separated list of origins allowed to call this proxy.
# Use "*" only in dev; tighten in prod.
ALLOWED_ORIGINS=http://localhost:8000,file://

# Default DIU template name used when V3 doesn't supply one
DEFAULT_TEMPLATE=IFRS_Loan_GL_DIU_Template

# Verbose request logging (1 = on)
LOG_VERBOSE=1
