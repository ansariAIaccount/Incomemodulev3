# ─────────────────────────────────────────────────────────────────────
# PCS Ingestion Service — env template
# Copy to `.env` (same folder), fill in the values, restart the server.
# ─────────────────────────────────────────────────────────────────────

# Where the ingest service listens. Default 4319. Cloud hosts (Render / Fly /
# Heroku / Railway) inject $PORT, which overrides this.
INGEST_PORT=4319

# CORS whitelist for the browser client. Use * during local dev; lock down in prod.
ALLOWED_ORIGINS=*

# ─── Anthropic API (required for real extraction; leave blank for mock mode) ─
# Get a key from https://console.anthropic.com → API Keys.
# Add credits under Settings → Billing (min $5). Typical notice extraction ≈ $0.05.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Verbose request logging (helpful when tuning prompts). Off in prod.
LOG_VERBOSE=0
